<!DOCTYPE html>
<html>
<head>
    <title>NxtQ CRM - Billing Management</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="/css/crm-style.css" rel="stylesheet">
    <style>
        .billing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-bottom: 2rem; }
        .cost-card { background: var(--surface); border-radius: 16px; padding: 2rem; box-shadow: var(--shadow-md); border: 1px solid var(--border); text-center; }
        .cost-amount { font-size: 2rem; font-weight: 700; color: var(--primary); margin-bottom: 0.5rem; }
        .cost-label { color: var(--text-secondary); font-size: 0.875rem; }
    </style>
</head>
<body>
    <div class="app-layout">
        <!-- Sidebar Navigation -->
        <div class="sidebar">
            <div class="sidebar-header">
                <h1><i class="fab fa-whatsapp"></i> NxtQ Support</h1>
                <p>WhatsApp Business CRM</p>
            </div>
            <nav class="sidebar-nav">
                <a href="/" class="sidebar-nav-item">
                    <i class="fas fa-home"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/crm" class="sidebar-nav-item">
                    <i class="fas fa-robot"></i>
                    <span>AI Agents</span>
                </a>
                <a href="/analytics" class="sidebar-nav-item">
                    <i class="fas fa-chart-line"></i>
                    <span>Analytics</span>
                </a>
                <a href="/tags" class="sidebar-nav-item">
                    <i class="fas fa-tags"></i>
                    <span>Tags</span>
                </a>
                <a href="/sla" class="sidebar-nav-item">
                    <i class="fas fa-clock"></i>
                    <span>SLA Management</span>
                </a>
                <a href="/feedback" class="sidebar-nav-item">
                    <i class="fas fa-star"></i>
                    <span>Feedback</span>
                </a>
                <a href="/billing" class="sidebar-nav-item active">
                    <i class="fas fa-credit-card"></i>
                    <span>Billing</span>
                </a>
                <a href="/settings" class="sidebar-nav-item">
                    <i class="fas fa-cog"></i>
                    <span>Settings</span>
                </a>
            </nav>
        </div>
        
        <!-- Main Content -->
        <div class="main-content">
            <div class="container">
                <div class="page-header">
                    <h1 class="page-title"><i class="fas fa-credit-card"></i> Billing & Usage</h1>
                    <p class="page-subtitle">Track API usage and conversation costs</p>
                </div>
                
                <div class="billing-grid">
                    <div class="cost-card">
                        <div class="cost-amount">₹0.00</div>
                        <div class="cost-label">This Month</div>
                    </div>
                    <div class="cost-card">
                        <div class="cost-amount">₹0.00</div>
                        <div class="cost-label">Text Messages</div>
                    </div>
                    <div class="cost-card">
                        <div class="cost-amount">₹0.00</div>
                        <div class="cost-label">Audio Processing</div>
                    </div>
                    <div class="cost-card">
                        <div class="cost-amount">₹0.00</div>
                        <div class="cost-label">Image Analysis</div>
                    </div>
                </div>
                
                <div class="coming-soon">
                    <i class="fas fa-credit-card"></i>
                    <h3>Billing & Cost Tracking</h3>
                    <p>Detailed usage analytics, cost breakdowns, and billing reports coming in Phase 3</p>
                    <div class="mt-4">
                        <div class="btn btn-primary">
                            <i class="fas fa-download"></i> Export Usage Report
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>