<%- include('partials/layout-header', { title: 'Wallet', currentPage: 'wallet' }) %>

<div class="content-header">
    <h1><i class="fas fa-wallet"></i> My Wallet</h1>
    <p>View your wallet balance and transaction history</p>
</div>

<!-- Wallet Overview Cards -->
<div class="card-grid">
    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-coins" style="color: var(--primary-color);"></i> Current Balance</h3>
            <div class="muted">Available funds</div>
        </div>
        <div class="card-content">
            <div class="stat-number">$<%= (wallet.balance_usd_micro / 1000000).toFixed(6) %></div>
            <div class="stat-sub">₹<%= ((wallet.balance_usd_micro / 1000000) * exchangeRate.rate).toFixed(2) %></div>
            <div class="muted" style="margin-top: 0.5rem;">
                <i class="fas fa-exchange-alt"></i> 1 USD = ₹<%= exchangeRate.rate %>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-rupee-sign" style="color: var(--success-color);"></i> Total Spent</h3>
            <div class="muted">All time usage</div>
        </div>
        <div class="card-content">
            <div class="stat-number">₹<%= totalSpentINR.toFixed(2) %></div>
            <div class="stat-sub">Total expenditure</div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-comments" style="color: var(--accent-color);"></i> Messages</h3>
            <div class="muted">Total processed</div>
        </div>
        <div class="card-content">
            <div class="stat-number"><%= totalMessages %></div>
            <div class="stat-sub">Messages handled</div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-calculator" style="color: var(--warning-color);"></i> Average Cost</h3>
            <div class="muted">Per message</div>
        </div>
        <div class="card-content">
            <div class="stat-number">₹<%= avgCostINR.toFixed(4) %></div>
            <div class="stat-sub">Cost efficiency</div>
        </div>
    </div>
</div>

<!-- Recent Transactions -->
<div class="card" style="margin-top: 2rem;">
    <div class="card-header">
        <h3><i class="fas fa-history"></i> Recent Transactions</h3>
    </div>
    <div class="card-content">
        <% if (transactions.length === 0) { %>
            <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
                <i class="fas fa-receipt" style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.3;"></i>
                <h3 style="margin-bottom: 0.5rem;">No transactions yet</h3>
                <p>Your transaction history will appear here once you start using the service.</p>
            </div>
        <% } else { %>
            <div style="overflow-x: auto;">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th>Description</th>
                            <th>Amount (INR)</th>
                            <th>Amount (USD)</th>
                            <th>Rate</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% transactions.forEach(transaction => { %>
                            <tr>
                                <td>
                                    <% if (transaction.transaction_type === 'credit') { %>
                                        <span style="color: var(--success-color); font-weight: 500;">
                                            <i class="fas fa-plus-circle"></i> Credit
                                        </span>
                                    <% } else { %>
                                        <span style="color: var(--error-color); font-weight: 500;">
                                            <i class="fas fa-minus-circle"></i> Debit
                                        </span>
                                    <% } %>
                                </td>
                                <td><%= transaction.description %></td>
                                <td style="color: <%= transaction.transaction_type === 'credit' ? 'var(--success-color)' : 'var(--error-color)' %>; font-weight: 500;">
                                    <%= transaction.transaction_type === 'credit' ? '+' : '-' %>₹<%= transaction.amount_inr %>
                                </td>
                                <td>$<%= (transaction.amount_usd_micro / 1000000).toFixed(6) %></td>
                                <td>₹<%= transaction.exchange_rate %></td>
                                <td><%= new Date(transaction.createdAt).toLocaleString() %></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>

<!-- Usage Summary -->
<div class="card" style="margin-top: 2rem;">
    <div class="card-header">
        <h3><i class="fas fa-chart-pie"></i> Usage Summary (Last 30 Days)</h3>
    </div>
    <div class="card-content">
        <% if (usageSummary.length === 0) { %>
            <div style="text-align: center; padding: 2rem; color: var(--text-muted);">
                <i class="fas fa-chart-bar" style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.3;"></i>
                <h3 style="margin-bottom: 0.5rem;">No usage data yet</h3>
                <p>Start using AI services to see your usage breakdown here.</p>
            </div>
        <% } else { %>
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem;">
                <% usageSummary.forEach(service => { %>
                    <div style="padding: 1rem; border: 1px solid var(--border-color); border-radius: 8px; background: var(--surface-color);">
                        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
                            <div style="width: 40px; height: 40px; border-radius: 8px; background: var(--primary-color); color: white; display: flex; align-items: center; justify-content: center;">
                                <% if (service.service_type === 'sentiment') { %>
                                    <i class="fas fa-smile"></i>
                                <% } else if (service.service_type === 'intent') { %>
                                    <i class="fas fa-bullseye"></i>
                                <% } else if (service.service_type === 'agent_process') { %>
                                    <i class="fas fa-robot"></i>
                                <% } else if (service.service_type === 'vision') { %>
                                    <i class="fas fa-eye"></i>
                                <% } else if (service.service_type === 'stt') { %>
                                    <i class="fas fa-microphone"></i>
                                <% } else { %>
                                    <i class="fas fa-cog"></i>
                                <% } %>
                            </div>
                            <div>
                                <div style="font-weight: 600; text-transform: capitalize;"><%= service.service_type.replace('_', ' ') %></div>
                                <div style="color: var(--text-muted); font-size: 0.9rem;"><%= service.count %> uses</div>
                            </div>
                        </div>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div style="color: var(--text-secondary); font-size: 0.9rem;">Total Cost</div>
                            <div>
                                <div style="font-weight: 600; color: var(--primary-color);">₹<%= (service.total_cost * exchangeRate.rate).toFixed(4) %></div>
                                <div style="color: var(--text-muted); font-size: 0.8rem;">$<%= service.total_cost.toFixed(6) %></div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
</div>

<% if (typeof user !== 'undefined' && user.role === 'admin') { %>
<!-- Add Balance Modal (Admin Only) -->
<div id="addBalanceModal" class="modal" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-plus-circle"></i> Add Balance to Wallet</h3>
            <span class="close" onclick="closeAddBalanceModal()">&times;</span>
        </div>
        <div class="modal-body">
            <form id="addBalanceForm">
                <div class="form-group">
                    <label for="addAmountINR">Amount (INR)</label>
                    <div class="input-group">
                        <span class="input-prefix">₹</span>
                        <input type="number" id="addAmountINR" step="1" min="1" placeholder="Enter amount" required>
                    </div>
                    <small class="form-text"><i class="fas fa-info-circle"></i> Exchange Rate: 1 USD = ₹<%= exchangeRate.rate %></small>
                </div>
                <div class="conversion-display">
                    <div class="conversion-row">
                        <span>USD Equivalent:</span>
                        <span id="usdEquivalent" class="conversion-amount">$0.00</span>
                    </div>
                </div>
                <div class="modal-actions">
                    <button type="button" class="btn btn-secondary" onclick="closeAddBalanceModal()">
                        <i class="fas fa-times"></i> Cancel
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Add Balance
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

    <style>
        /* Wallet-specific styles that extend the main CRM styles */
