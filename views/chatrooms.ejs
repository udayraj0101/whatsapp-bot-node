<%- include('partials/layout-header', { title: 'Dashboard', currentPage: 'dashboard' }) %>

<div class="content-header">
    <h1><i class="fas fa-home"></i> Dashboard</h1>
    <p>Monitor and manage your WhatsApp customer conversations</p>
</div>

<div class="stats">
    <div class="stat-card">
        <div class="stat-header">
            <div class="stat-icon" style="background: linear-gradient(135deg, #3b82f6, #1d4ed8); color: white;">
                <i class="fas fa-comments"></i>
            </div>
        </div>
        <div class="stat-number"><%= chatrooms.length %></div>
        <div class="stat-label">Total Conversations</div>
    </div>
    <div class="stat-card">
        <div class="stat-header">
            <div class="stat-icon" style="background: linear-gradient(135deg, #10b981, #059669); color: white;">
                <i class="fas fa-clock"></i>
            </div>
        </div>
        <div class="stat-number"><%= chatrooms.filter(c => new Date() - new Date(c.updatedAt) < 24*60*60*1000).length %></div>
        <div class="stat-label">Active Today</div>
    </div>
    <div class="stat-card">
        <div class="stat-header">
            <div class="stat-icon" style="background: linear-gradient(135deg, #f59e0b, #d97706); color: white;">
                <i class="fas fa-calendar-week"></i>
            </div>
        </div>
        <div class="stat-number"><%= chatrooms.filter(c => new Date() - new Date(c.updatedAt) < 7*24*60*60*1000).length %></div>
        <div class="stat-label">This Week</div>
    </div>
    <div class="stat-card">
        <div class="stat-header">
            <div class="stat-icon" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed); color: white;">
                <i class="fas fa-check-circle"></i>
            </div>
        </div>
        <div class="stat-number"><%= analytics.resolution ? analytics.resolution.resolutionRate : 0 %>%</div>
        <div class="stat-label">AI Resolution Rate</div>
        <div class="stat-detail"><%= analytics.resolution ? analytics.resolution.resolvedQueries : 0 %>/<%= analytics.resolution ? analytics.resolution.analyzedResponses : 0 %> queries resolved</div>
    </div>
</div>

<!-- Analytics Section -->
<div class="analytics-section">
    <div class="section-header">
        <h2 class="section-title"><i class="fas fa-chart-line"></i> Analytics Overview</h2>
    </div>
    
    <div class="analytics-stats">
        <div class="analytics-card">
            <div class="analytics-icon positive">
                <i class="fas fa-smile"></i>
            </div>
            <div class="analytics-details">
                <h3><%= analytics ? analytics.sentiments.positive : 0 %></h3>
                <p>Positive Sentiment</p>
            </div>
        </div>
        <div class="analytics-card">
            <div class="analytics-icon warning">
                <i class="fas fa-meh"></i>
            </div>
            <div class="analytics-details">
                <h3><%= analytics ? analytics.sentiments.neutral : 0 %></h3>
                <p>Neutral Sentiment</p>
            </div>
        </div>
        <div class="analytics-card">
            <div class="analytics-icon negative">
                <i class="fas fa-frown"></i>
            </div>
            <div class="analytics-details">
                <h3><%= analytics ? analytics.sentiments.negative : 0 %></h3>
                <p>Negative Sentiment</p>
            </div>
        </div>
        <div class="analytics-card">
            <div class="analytics-icon">
                <i class="fas fa-brain"></i>
            </div>
            <div class="analytics-details">
                <h3><%= analytics ? analytics.totalAnalyzed : 0 %></h3>
                <p>Messages Analyzed</p>
            </div>
        </div>
        <div class="analytics-card">
            <div class="analytics-icon" style="background: linear-gradient(135deg, #06b6d4, #0891b2);">
                <i class="fas fa-bullseye"></i>
            </div>
            <div class="analytics-details">
                <h3><%= analytics.resolution ? analytics.resolution.avgConfidence : 0 %>%</h3>
                <p>Avg Resolution Confidence</p>
            </div>
        </div>
    </div>
    
    <div class="intent-overview">
        <div class="card">
            <div class="card-header">
                <h3>Intent Distribution</h3>
            </div>
            <div class="card-content">
                <div class="intent-stats">
                    <div class="intent-item">
                        <span class="intent-label">Queries</span>
                        <span class="intent-count"><%= analytics ? analytics.intents.query : 0 %></span>
                    </div>
                    <div class="intent-item">
                        <span class="intent-label">Complaints</span>
                        <span class="intent-count"><%= analytics ? analytics.intents.complaint : 0 %></span>
                    </div>
                    <div class="intent-item">
                        <span class="intent-label">Action Required</span>
                        <span class="intent-count"><%= analytics ? analytics.intents.need_action : 0 %></span>
                    </div>
                    <div class="intent-item">
                        <span class="intent-label">Feedback</span>
                        <span class="intent-count"><%= analytics ? analytics.intents.feedback : 0 %></span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
}

.stat-card {
    background: var(--surface-color);
    padding: 2rem;
    border-radius: 16px;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
}

.stat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
}

.stat-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
}

.stat-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
}

.stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

.stat-label {
    color: var(--text-secondary);
    font-weight: 500;
}

.stat-detail {
    color: var(--text-muted);
    font-size: 0.8rem;
    margin-top: 0.25rem;
}

.section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
}

.section-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
}

.search-box {
    position: relative;
}

.search-box input {
    padding: 0.75rem 1rem 0.75rem 3rem;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--surface-color);
    width: 300px;
}

.search-box i {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary);
}

.analytics-section {
    margin-bottom: 3rem;
}

.analytics-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
}

.analytics-card {
    background: var(--surface-color);
    padding: 1.5rem;
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    gap: 1rem;
}

.analytics-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    background: var(--primary-color);
    color: white;
}

.analytics-icon.positive { background: var(--success-color); }
.analytics-icon.warning { background: var(--warning-color); }
.analytics-icon.negative { background: var(--error-color); }

.analytics-details h3 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    color: var(--text-primary);
}

.analytics-details p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.85rem;
}

.intent-overview {
    max-width: 400px;
}

.intent-stats {
    display: grid;
    gap: 0.75rem;
}

.intent-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: var(--background-color);
    border-radius: 6px;
}

.intent-label {
    font-weight: 500;
    color: var(--text-primary);
    font-size: 0.9rem;
}

.intent-count {
    font-weight: 700;
    color: var(--primary-color);
}



.empty-state {
    text-align: center;
    padding: 6rem 2rem;
}

.empty-state-icon {
    width: 80px;
    height: 80px;
    border-radius: 20px;
    background: linear-gradient(135deg, var(--primary-light), var(--primary-color));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 2rem;
    box-shadow: var(--shadow-lg);
}

.empty-state-icon i {
    font-size: 2rem;
    color: white;
}

.empty-state h3 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

.empty-state p {
    color: var(--text-secondary);
    max-width: 400px;
    margin: 0 auto;
}

.sla-badge {
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: capitalize;
}

.sla-new { background: #e0f2fe; color: #0277bd; }
.sla-pending { background: #fff3e0; color: #f57c00; }
.sla-overdue { background: #ffebee; color: #d32f2f; }
.sla-closed { background: #e8f5e8; color: #388e3c; }

.sentiment-positive, .sentiment-neutral, .sentiment-negative {
    padding: 0.2rem 0.4rem;
    border-radius: 8px;
    font-size: 0.75rem;
    font-weight: 500;
    margin: 0 0.2rem;
}

@media (max-width: 768px) {
    .stats { grid-template-columns: 1fr; }
    .search-box input { width: 100%; }
    .chatroom-meta { grid-template-columns: 1fr; }
}
</style>

<script>
// Search functionality
document.getElementById('searchInput')?.addEventListener('input', function(e) {
    const searchTerm = e.target.value.toLowerCase();
    const chatrooms = document.querySelectorAll('.chatroom');
    
    chatrooms.forEach(chatroom => {
        const text = chatroom.textContent.toLowerCase();
        const parent = chatroom.parentElement;
        if (text.includes(searchTerm)) {
            parent.style.display = 'block';
        } else {
            parent.style.display = 'none';
        }
    });
});
</script>

<%- include('partials/layout-footer') %>