<%- include('./partials/layout-header', { title: vendor.company_name, currentPage: 'admin' }) %>

<div class="content-header">
    <div class="header-left">
        <h1><i class="fas fa-building"></i> <%= vendor.company_name %></h1>
        <p>Vendor details and statistics</p>
    </div>
    <div class="header-actions">
        <button class="btn btn-secondary" onclick="toggleVendor('<%= vendor.vendor_id %>')">
            <i class="fas fa-<%= vendor.is_active ? 'pause' : 'play' %>"></i>
            <%= vendor.is_active ? 'Deactivate' : 'Activate' %>
        </button>
    </div>
</div>

<div class="vendor-detail-grid">
    <!-- Vendor Information -->
    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-info-circle"></i> Vendor Information</h3>
        </div>
        <div class="card-content">
            <div class="info-grid">
                <div class="info-item">
                    <label>Company Name</label>
                    <value><%= vendor.company_name %></value>
                </div>
                <div class="info-item">
                    <label>Email</label>
                    <value><%= vendor.email %></value>
                </div>
                <div class="info-item">
                    <label>Phone</label>
                    <value><%= vendor.phone || 'Not provided' %></value>
                </div>
                <div class="info-item">
                    <label>Vendor ID</label>
                    <value><%= vendor.vendor_id %></value>
                </div>
                <div class="info-item">
                    <label>Status</label>
                    <value>
                        <span class="status-badge <%= vendor.is_active ? 'active' : 'inactive' %>">
                            <%= vendor.is_active ? 'Active' : 'Inactive' %>
                        </span>
                    </value>
                </div>
                <div class="info-item">
                    <label>Subscription</label>
                    <value><%= vendor.subscription_plan || 'Basic' %></value>
                </div>
                <div class="info-item">
                    <label>Created</label>
                    <value><%= new Date(vendor.createdAt).toLocaleDateString() %></value>
                </div>
                <div class="info-item">
                    <label>WhatsApp Phone ID</label>
                    <value><%= vendor.whatsapp_phone_id || 'Not configured' %></value>
                </div>
            </div>
        </div>
    </div>

    <!-- Usage Statistics -->
    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-chart-bar"></i> Usage Statistics</h3>
        </div>
        <div class="card-content">
            <div class="stats-grid">
                <div class="stat-item">
                    <div class="stat-number"><%= vendorStats.chatroomCount %></div>
                    <div class="stat-label">Conversations</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number"><%= vendorStats.messageCount %></div>
                    <div class="stat-label">Messages</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">$<%= (vendorStats.wallet.balance_usd_micro / 1000000).toFixed(2) %></div>
                    <div class="stat-label">Wallet Balance</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">₹<%= ((vendorStats.wallet.balance_usd_micro / 1000000) * vendorStats.exchangeRate).toFixed(2) %></div>
                    <div class="stat-label">Balance (INR)</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Top-ups -->
    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-plus-circle"></i> Recent Top-ups</h3>
        </div>
        <div class="card-content">
            <% if (vendorStats.recentTopups.length > 0) { %>
                <div class="transaction-list">
                    <% vendorStats.recentTopups.forEach(topup => { %>
                        <div class="transaction-item">
                            <div class="transaction-info">
                                <div class="transaction-amount">₹<%= topup.amount_inr.toLocaleString() %></div>
                                <div class="transaction-date"><%= new Date(topup.createdAt).toLocaleDateString() %></div>
                            </div>
                            <div class="transaction-details">
                                <div class="transaction-desc"><%= topup.description || 'Wallet top-up' %></div>
                                <div class="transaction-by">By: <%= topup.added_by %></div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-message">
                    <i class="fas fa-plus-circle"></i>
                    <p>No top-ups recorded</p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Recent Usage -->
    <div class="card">
        <div class="card-header">
            <h3><i class="fas fa-receipt"></i> Recent Usage</h3>
        </div>
        <div class="card-content">
            <% if (vendorStats.recentUsage.length > 0) { %>
                <div class="usage-list">
                    <% vendorStats.recentUsage.forEach(usage => { %>
                        <div class="usage-item">
                            <div class="usage-info">
                                <div class="usage-cost">$<%= (usage.final_cost_usd_micro / 1000000).toFixed(6) %></div>
                                <div class="usage-date"><%= new Date(usage.charged_at).toLocaleDateString() %></div>
                            </div>
                            <div class="usage-details">
                                <div class="usage-phone"><%= usage.phone_number %></div>
                                <div class="usage-window"><%= usage.conversation_window ? usage.conversation_window.replace('_', ' ') : 'N/A' %></div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-message">
                    <i class="fas fa-receipt"></i>
                    <p>No usage recorded</p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<style>
.content-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
}

.header-actions {
    display: flex;
    gap: 1rem;
}

.vendor-detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
}

.info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}

.info-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.info-item label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.info-item value {
    font-weight: 500;
    color: var(--text-primary);
}

.status-badge {
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
}

.status-badge.active {
    background: var(--success-light);
    color: var(--success-color);
}

.status-badge.inactive {
    background: var(--error-light);
    color: var(--error-color);
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
}

.stat-item {
    text-align: center;
    padding: 1rem;
    background: var(--background-color);
    border-radius: 8px;
}

.stat-number {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--primary-color);
    margin-bottom: 0.25rem;
}

.stat-label {
    font-size: 0.8rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.transaction-list, .usage-list {
    display: grid;
    gap: 0.75rem;
}

.transaction-item, .usage-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem;
    background: var(--background-color);
    border-radius: 8px;
}

.transaction-amount, .usage-cost {
    font-weight: 700;
    color: var(--success-color);
}

.usage-cost {
    color: var(--warning-color);
}

.transaction-date, .usage-date {
    font-size: 0.8rem;
    color: var(--text-muted);
}

.transaction-desc, .usage-phone {
    font-weight: 500;
    color: var(--text-primary);
}

.transaction-by, .usage-window {
    font-size: 0.8rem;
    color: var(--text-secondary);
}

.empty-message {
    text-align: center;
    padding: 2rem;
    color: var(--text-muted);
}

.empty-message i {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    color: var(--primary-light);
}

.btn {
    padding: 0.5rem 1rem;
    border-radius: 6px;
    border: none;
    font-weight: 500;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: all 0.2s;
}

.btn-secondary {
    background: var(--background-color);
    color: var(--text-primary);
    border: 1px solid var(--border-color);
}

.btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}

@media (max-width: 768px) {
    .vendor-detail-grid {
        grid-template-columns: 1fr;
    }
    
    .info-grid {
        grid-template-columns: 1fr;
    }
    
    .stats-grid {
        grid-template-columns: 1fr;
    }
    
    .content-header {
        flex-direction: column;
        gap: 1rem;
    }
}
</style>

<script>
async function toggleVendor(vendorId) {
    try {
        const response = await fetch(`/admin/vendors/${vendorId}/toggle`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' }
        });
        
        if (response.ok) {
            location.reload();
        } else {
            alert('Failed to update vendor status');
        }
    } catch (error) {
        alert('Error updating vendor status');
    }
}
</script>

<%- include('partials/layout-footer') %>