<div class="sidebar admin-sidebar">
    <div class="sidebar-header">
        <div class="logo">
            <i class="fas fa-tools"></i>
            <div>
                <h1>Admin</h1>
                <span>System Panel</span>
            </div>
        </div>
    </div>

    <nav class="sidebar-nav">
        <a href="/admin" class="sidebar-nav-item <%= requestPath === '/admin' ? 'active' : '' %>">
            <i class="fas fa-home"></i>
            <span>Dashboard</span>
        </a>
        <a href="/admin/vendors" class="sidebar-nav-item <%= requestPath && requestPath.startsWith('/admin/vendors') ? 'active' : '' %>">
            <i class="fas fa-building"></i>
            <span>Vendors</span>
        </a>
        <a href="/admin/wallet" class="sidebar-nav-item <%= requestPath && requestPath.startsWith('/admin/wallet') ? 'active' : '' %>">
            <i class="fas fa-wallet"></i>
            <span>Wallet Management</span>
        </a>
        <a href="/admin/topup-history" class="sidebar-nav-item <%= requestPath && requestPath.startsWith('/admin/topup-history') ? 'active' : '' %>">
            <i class="fas fa-plus-circle"></i>
            <span>Top-up History</span>
        </a>
        <a href="/admin/billing-history" class="sidebar-nav-item <%= requestPath && requestPath.startsWith('/admin/billing-history') ? 'active' : '' %>">
            <i class="fas fa-receipt"></i>
            <span>Billing History</span>
        </a>
        <a href="/admin/pricing-config" class="sidebar-nav-item <%= requestPath && requestPath.startsWith('/admin/pricing-config') ? 'active' : '' %>">
            <i class="fas fa-dollar-sign"></i>
            <span>Pricing Config</span>
        </a>
        <a href="/admin/logout" class="sidebar-nav-item">
            <i class="fas fa-sign-out-alt"></i>
            <span>Logout</span>
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="user-info">
            <div class="user-avatar">
                <i class="fas fa-user-shield"></i>
            </div>
            <div class="user-details">
                <div class="user-name"><%= (typeof admin !== 'undefined' && admin && admin.name) ? admin.name : (typeof vendor !== 'undefined' && vendor && vendor.company_name) ? vendor.company_name : 'Admin' %></div>
                <div class="user-role">System Administrator</div>
            </div>
        </div>
    </div>
</div>