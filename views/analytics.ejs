<%- include('partials/layout-header', { title: 'Analytics', currentPage: 'analytics' }) %>

<div class="content-header">
    <h1><i class="fas fa-chart-line"></i> Analytics Dashboard</h1>
    <p>AI insights and conversation analytics</p>
</div>

<div class="analytics-dashboard">
    <div class="stats-grid">
        <div class="card">
            <div class="card-content">
                <div class="stat-item">
                    <div class="stat-icon">
                        <i class="fas fa-comments"></i>
                    </div>
                    <div class="stat-details">
                        <h3><%= analytics.totalAnalyzed %></h3>
                        <p>Messages Analyzed</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-content">
                <div class="stat-item">
                    <div class="stat-icon positive">
                        <i class="fas fa-smile"></i>
                    </div>
                    <div class="stat-details">
                        <h3><%= analytics.sentiments.positive %></h3>
                        <p>Positive Sentiment</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-content">
                <div class="stat-item">
                    <div class="stat-icon warning">
                        <i class="fas fa-meh"></i>
                    </div>
                    <div class="stat-details">
                        <h3><%= analytics.sentiments.neutral %></h3>
                        <p>Neutral Sentiment</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-content">
                <div class="stat-item">
                    <div class="stat-icon negative">
                        <i class="fas fa-frown"></i>
                    </div>
                    <div class="stat-details">
                        <h3><%= analytics.sentiments.negative %></h3>
                        <p>Negative Sentiment</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="charts-grid">
        <div class="card">
            <div class="card-header">
                <h3>Intent Distribution</h3>
            </div>
            <div class="card-content">
                <div class="intent-stats">
                    <div class="intent-item">
                        <span class="intent-label">Queries</span>
                        <span class="intent-count"><%= analytics.intents.query %></span>
                    </div>
                    <div class="intent-item">
                        <span class="intent-label">Complaints</span>
                        <span class="intent-count"><%= analytics.intents.complaint %></span>
                    </div>
                    <div class="intent-item">
                        <span class="intent-label">Action Required</span>
                        <span class="intent-count"><%= analytics.intents.need_action %></span>
                    </div>
                    <div class="intent-item">
                        <span class="intent-label">Feedback</span>
                        <span class="intent-count"><%= analytics.intents.feedback %></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3>Sentiment Trends</h3>
            </div>
            <div class="card-content">
                <div class="sentiment-chart">
                    <div class="chart-placeholder">
                        <i class="fas fa-chart-bar"></i>
                        <p>Advanced charts coming in Phase 2</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.analytics-dashboard {
    display: grid;
    gap: 2rem;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
}

.stat-item {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    background: var(--primary-color);
    color: white;
}

.stat-icon.positive {
    background: var(--success-color);
}

.stat-icon.warning {
    background: var(--warning-color);
}

.stat-icon.negative {
    background: var(--error-color);
}

.stat-details h3 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    color: var(--text-primary);
}

.stat-details p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.charts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
}

.intent-stats {
    display: grid;
    gap: 1rem;
}

.intent-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem;
    background: var(--background-color);
    border-radius: 8px;
}

.intent-label {
    font-weight: 500;
    color: var(--text-primary);
}

.intent-count {
    font-weight: 700;
    color: var(--primary-color);
    font-size: 1.1rem;
}

.chart-placeholder {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
}

.chart-placeholder i {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: var(--primary-light);
}

@media (max-width: 768px) {
    .charts-grid {
        grid-template-columns: 1fr;
    }
    
    .stats-grid {
        grid-template-columns: 1fr;
    }
}
</style>

<%- include('partials/layout-footer') %>