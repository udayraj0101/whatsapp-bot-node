<%- include('partials/layout-header', { title: 'Conversations', currentPage: 'conversations' }) %>

<div class="content-header">
    <h1><i class="fas fa-comments"></i> Conversations</h1>
    <p>Manage all customer conversations and interactions</p>
</div>

<div class="section-header">
    <h2 class="section-title"><i class="fas fa-comments"></i> All Conversations</h2>
    <div class="search-box">
        <i class="fas fa-search"></i>
        <input type="text" placeholder="Search conversations..." id="searchInput">
    </div>
</div>

<div class="chatrooms-grid">
    <% if (chatrooms.length === 0) { %>
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="fas fa-comments"></i>
            </div>
            <h3>No conversations yet</h3>
            <p>Customer conversations will appear here once they start chatting with your WhatsApp Business account</p>
        </div>
    <% } else { %>
        <% chatrooms.forEach(chatroom => { %>
            <% const isActive = new Date() - new Date(chatroom.updatedAt) < 24*60*60*1000; %>
            <a href="/chatroom/<%= chatroom._id %>">
                <div class="chatroom">
                    <div class="chatroom-header">
                        <div class="customer-info">
                            <div class="avatar">
                                <%= chatroom.phone_number.slice(-2) %>
                            </div>
                            <div class="customer-details">
                                <h3><%= chatroom.phone_number %></h3>
                                <p>Thread: <%= chatroom.thread_id.substring(0, 16) %>...</p>
                            </div>
                        </div>
                        <div class="status-badge <%= isActive ? 'status-active' : 'status-inactive' %>">
                            <i class="fas fa-circle" style="font-size: 0.5rem; margin-right: 0.25rem;"></i>
                            <%= isActive ? 'Active' : 'Inactive' %>
                        </div>
                    </div>
                    
                    <div class="chatroom-meta">
                        <div class="meta-item">
                            <i class="fas fa-building"></i>
                            Business ID: <%= chatroom.business_id %>
                        </div>
                        <div class="meta-item">
                            <i class="fas fa-robot"></i>
                            Agent ID: <%= chatroom.agent_id %>
                        </div>
                        <% if (chatroom.latestIntent) { %>
                        <div class="meta-item">
                            <i class="fas fa-brain"></i>
                            Intent: <span class="intent-badge intent-<%= chatroom.latestIntent %>"><%= chatroom.latestIntent %></span>
                        </div>
                        <% } %>
                        <% if (chatroom.conversationSentiment && chatroom.conversationSentiment.totalMessages > 0) { %>
                        <div class="meta-item">
                            <i class="fas fa-chart-pie"></i>
                            Sentiment: 
                            <span style="color: var(--success-color); font-weight: 500;"><%= chatroom.conversationSentiment.breakdown.positive %>%</span> |
                            <span style="color: var(--text-secondary); font-weight: 500;"><%= chatroom.conversationSentiment.breakdown.neutral %>%</span> |
                            <span style="color: var(--error-color); font-weight: 500;"><%= chatroom.conversationSentiment.breakdown.negative %>%</span>
                        </div>
                        <% } %>
                        <% if (chatroom.slaInfo) { %>
                        <div class="meta-item">
                            <i class="fas fa-clock"></i>
                            SLA: <span class="sla-badge sla-<%= chatroom.slaInfo.status %>"><%= chatroom.slaInfo.status %></span>
                            <% if (chatroom.slaInfo.status !== 'closed' && chatroom.slaInfo.hoursRemaining > 0) { %>
                                (<%= chatroom.slaInfo.hoursRemaining %>h left)
                            <% } %>
                        </div>
                        <% } %>
                    </div>
                    
                    <div class="last-activity">
                        <i class="fas fa-clock"></i>
                        Last: <%= new Date(chatroom.updatedAt).toLocaleString() %>
                    </div>
                    
                    <div class="last-message">
                        <div class="last-message-text">
                            <i class="fas fa-comment-dots"></i>
                            <% if (chatroom.aiAnalyzedMessages > 0) { %>
                                <%= chatroom.aiAnalyzedMessages %> AI-analyzed messages | 
                                <% if (chatroom.sentimentCounts.positive > 0) { %><span class="sentiment-positive">+<%= chatroom.sentimentCounts.positive %></span><% } %>
                                <% if (chatroom.sentimentCounts.neutral > 0) { %><span class="sentiment-neutral">~<%= chatroom.sentimentCounts.neutral %></span><% } %>
                                <% if (chatroom.sentimentCounts.negative > 0) { %><span class="sentiment-negative">-<%= chatroom.sentimentCounts.negative %></span><% } %>
                            <% } else { %>
                                Click to view conversation history and messages
                            <% } %>
                        </div>
                    </div>
                </div>
            </a>
        <% }) %>
    <% } %>
</div>

<style>
.section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
}

.section-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
}

.search-box {
    position: relative;
}

.search-box input {
    padding: 0.75rem 1rem 0.75rem 3rem;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--surface-color);
    width: 300px;
}

.search-box i {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary);
}

.chatrooms-grid {
    display: grid;
    gap: 1.5rem;
}

.chatrooms-grid a {
    text-decoration: none;
    color: inherit;
}

.chatroom {
    background: var(--surface-color);
    border-radius: 16px;
    padding: 2rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
    position: relative;
}

.chatroom::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: linear-gradient(180deg, var(--primary-color), var(--accent-color));
    border-radius: 16px 0 0 16px;
}

.chatroom:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.chatroom-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
}

.customer-info {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.avatar {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    box-shadow: var(--shadow-md);
}

.customer-details h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
}

.customer-details p {
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.status-badge {
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
}

.status-active {
    background: #dcfce7;
    color: #166534;
    border: 1px solid #bbf7d0;
}

.status-inactive {
    background: #fef3c7;
    color: #92400e;
    border: 1px solid #fde68a;
}

.chatroom-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
}

.meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.meta-item i {
    width: 16px;
    text-align: center;
}

.last-activity {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 1rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border-color);
}

.last-activity i {
    width: 16px;
    text-align: center;
}

.last-message {
    background: #f1f5f9;
    padding: 1rem;
    border-radius: 8px;
    margin-top: 1rem;
    border-left: 3px solid var(--primary-color);
}

.last-message-text {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.4;
}

.empty-state {
    text-align: center;
    padding: 6rem 2rem;
}

.empty-state-icon {
    width: 80px;
    height: 80px;
    border-radius: 20px;
    background: linear-gradient(135deg, var(--primary-light), var(--primary-color));
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 2rem;
    box-shadow: var(--shadow-lg);
}

.empty-state-icon i {
    font-size: 2rem;
    color: white;
}

.empty-state h3 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

.empty-state p {
    color: var(--text-secondary);
    max-width: 400px;
    margin: 0 auto;
}

.sla-badge {
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: capitalize;
}

.sla-new { background: #e0f2fe; color: #0277bd; }
.sla-pending { background: #fff3e0; color: #f57c00; }
.sla-overdue { background: #ffebee; color: #d32f2f; }
.sla-closed { background: #e8f5e8; color: #388e3c; }

.intent-badge, .sentiment-badge {
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: capitalize;
}

.intent-query { background: #e0f2fe; color: #0277bd; }
.intent-complaint { background: #ffebee; color: #d32f2f; }
.intent-need_action { background: #fff3e0; color: #f57c00; }
.intent-feedback { background: #e8f5e8; color: #388e3c; }

.sentiment-positive { background: #e8f5e8; color: #388e3c; }
.sentiment-neutral { background: #f3f4f6; color: #6b7280; }
.sentiment-negative { background: #ffebee; color: #d32f2f; }

.conversation-sentiment {
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: capitalize;
    border: 1px solid;
}

.conversation-sentiment.sentiment-positive {
    background: #e8f5e8;
    color: #2e7d32;
    border-color: #a5d6a7;
}

.conversation-sentiment.sentiment-neutral {
    background: #f5f5f5;
    color: #616161;
    border-color: #e0e0e0;
}

.conversation-sentiment.sentiment-negative {
    background: #ffebee;
    color: #c62828;
    border-color: #ef9a9a;
}

@media (max-width: 768px) {
    .search-box input { width: 100%; }
    .chatroom-meta { grid-template-columns: 1fr; }
}
</style>

<script>
// Search functionality
document.getElementById('searchInput')?.addEventListener('input', function(e) {
    const searchTerm = e.target.value.toLowerCase();
    const chatrooms = document.querySelectorAll('.chatroom');
    
    chatrooms.forEach(chatroom => {
        const text = chatroom.textContent.toLowerCase();
        const parent = chatroom.parentElement;
        if (text.includes(searchTerm)) {
            parent.style.display = 'block';
        } else {
            parent.style.display = 'none';
        }
    });
});
</script>

<%- include('partials/layout-footer') %>