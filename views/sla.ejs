<%- include('partials/layout-header', { title: 'SLA Management', currentPage: 'sla' }) %>

<div class="content-header">
    <h1><i class="fas fa-clock"></i> SLA Management</h1>
    <p>Service Level Agreement tracking and performance metrics</p>
</div>

<div class="sla-dashboard">
    <!-- SLA Overview Stats -->
    <div class="sla-stats">
        <div class="card">
            <div class="card-content">
                <div class="stat-item">
                    <div class="stat-icon">
                        <i class="fas fa-plus-circle"></i>
                    </div>
                    <div class="stat-details">
                        <h3><%= slaStats.new %></h3>
                        <p>New Conversations</p>
                        <small>Just started</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-content">
                <div class="stat-item">
                    <div class="stat-icon warning">
                        <i class="fas fa-hourglass-half"></i>
                    </div>
                    <div class="stat-details">
                        <h3><%= slaStats.pending %></h3>
                        <p>Pending Response</p>
                        <small>Within 24h SLA</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-content">
                <div class="stat-item">
                    <div class="stat-icon negative">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <div class="stat-details">
                        <h3><%= slaStats.overdue %></h3>
                        <p>Overdue (>24h)</p>
                        <small>SLA Breached</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-content">
                <div class="stat-item">
                    <div class="stat-icon positive">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="stat-details">
                        <h3><%= slaStats.closed %></h3>
                        <p>Closed</p>
                        <small>Resolved</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SLA Performance Metrics -->
    <div class="sla-metrics">
        <div class="card">
            <div class="card-header">
                <h3><i class="fas fa-chart-line"></i> SLA Performance</h3>
            </div>
            <div class="card-content">
                <div class="metrics-grid">
                    <div class="metric-item">
                        <div class="metric-value <%= slaStats.slaCompliance >= 90 ? 'positive' : slaStats.slaCompliance >= 70 ? 'warning' : 'negative' %>">
                            <%= slaStats.slaCompliance %>%
                        </div>
                        <div class="metric-label">SLA Compliance</div>
                        <div class="metric-target">Target: 90%</div>
                    </div>
                    <div class="metric-item">
                        <div class="metric-value <%= slaStats.avgResponseTime <= 2 ? 'positive' : slaStats.avgResponseTime <= 6 ? 'warning' : 'negative' %>">
                            <%= slaStats.avgResponseTime %>h
                        </div>
                        <div class="metric-label">Avg Response Time</div>
                        <div class="metric-target">Target: <2h</div>
                    </div>
                    <div class="metric-item">
                        <div class="metric-value">
                            24h
                        </div>
                        <div class="metric-label">SLA Target</div>
                        <div class="metric-target">Response deadline</div>
                    </div>
                    <div class="metric-item">
                        <div class="metric-value">
                            <%= slaStats.total %>
                        </div>
                        <div class="metric-label">Total Conversations</div>
                        <div class="metric-target">All time</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Priority Queue -->
    <% if (overdueConversations && overdueConversations.length > 0) { %>
    <div class="priority-queue">
        <div class="card">
            <div class="card-header">
                <h3><i class="fas fa-exclamation-triangle"></i> Urgent: Overdue Conversations</h3>
                <span class="badge badge-danger"><%= overdueConversations.length %></span>
            </div>
            <div class="card-content">
                <div class="conversation-list">
                    <% overdueConversations.forEach(conv => { %>
                    <div class="conversation-item overdue">
                        <div class="conversation-info">
                            <div class="customer-avatar">
                                <%= conv.phone_number.slice(-2) %>
                            </div>
                            <div class="conversation-details">
                                <h4><%= conv.phone_number %></h4>
                                <p>Overdue by <%= conv.slaInfo.hoursOverdue %>h</p>
                                <% if (conv.latestIntent) { %>
                                <span class="intent-badge intent-<%= conv.latestIntent %>"><%= conv.latestIntent %></span>
                                <% } %>
                            </div>
                        </div>
                        <div class="conversation-actions">
                            <a href="/chatroom/<%= conv._id %>" class="btn btn-primary btn-sm">
                                <i class="fas fa-eye"></i> View
                            </a>
                            <button class="btn btn-success btn-sm" onclick="updateStatus('<%= conv._id %>', 'closed')">
                                <i class="fas fa-check"></i> Resolve
                            </button>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Due Soon Conversations -->
    <% if (dueSoonConversations && dueSoonConversations.length > 0) { %>
    <div class="due-soon-queue">
        <div class="card">
            <div class="card-header">
                <h3><i class="fas fa-clock"></i> Due Soon (< 2 hours left)</h3>
                <span class="badge badge-warning"><%= dueSoonConversations.length %></span>
            </div>
            <div class="card-content">
                <div class="conversation-list">
                    <% dueSoonConversations.forEach(conv => { %>
                    <div class="conversation-item due-soon">
                        <div class="conversation-info">
                            <div class="customer-avatar">
                                <%= conv.phone_number.slice(-2) %>
                            </div>
                            <div class="conversation-details">
                                <h4><%= conv.phone_number %></h4>
                                <p><%= conv.slaInfo.hoursRemaining %>h remaining</p>
                                <% if (conv.latestIntent) { %>
                                <span class="intent-badge intent-<%= conv.latestIntent %>"><%= conv.latestIntent %></span>
                                <% } %>
                            </div>
                        </div>
                        <div class="conversation-actions">
                            <a href="/chatroom/<%= conv._id %>" class="btn btn-primary btn-sm">
                                <i class="fas fa-eye"></i> View
                            </a>
                            <button class="btn btn-success btn-sm" onclick="updateStatus('<%= conv._id %>', 'closed')">
                                <i class="fas fa-check"></i> Resolve
                            </button>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
    <% } %>

    <!-- All Conversations by Status -->
    <div class="conversations-by-status">
        <div class="card">
            <div class="card-header">
                <h3><i class="fas fa-list"></i> All Conversations</h3>
                <div class="status-filters">
                    <button class="filter-btn active" data-status="all">All (<%= slaStats.total %>)</button>
                    <button class="filter-btn" data-status="new">New (<%= slaStats.new %>)</button>
                    <button class="filter-btn" data-status="pending">Pending (<%= slaStats.pending %>)</button>
                    <button class="filter-btn" data-status="overdue">Overdue (<%= slaStats.overdue %>)</button>
                    <button class="filter-btn" data-status="closed">Closed (<%= slaStats.closed %>)</button>
                </div>
            </div>
            <div class="card-content">
                <div class="conversation-list" id="allConversations">
                    <% allConversations.forEach(conv => { %>
                    <div class="conversation-item" data-status="<%= conv.slaInfo.status %>">
                        <div class="conversation-info">
                            <div class="customer-avatar">
                                <%= conv.phone_number.slice(-2) %>
                            </div>
                            <div class="conversation-details">
                                <h4><%= conv.phone_number %></h4>
                                <p>
                                    <% if (conv.slaInfo.status === 'overdue') { %>
                                        Overdue by <%= conv.slaInfo.hoursOverdue || 0 %>h
                                    <% } else if (conv.slaInfo.status === 'closed') { %>
                                        Resolved
                                    <% } else { %>
                                        <%= conv.slaInfo.hoursRemaining %>h remaining
                                    <% } %>
                                </p>
                                <div class="conversation-meta">
                                    <% if (conv.latestIntent) { %>
                                    <span class="intent-badge intent-<%= conv.latestIntent %>"><%= conv.latestIntent %></span>
                                    <% } %>
                                    <span class="sla-badge sla-<%= conv.slaInfo.status %>"><%= conv.slaInfo.status %></span>
                                    <span class="time-badge"><%= new Date(conv.updatedAt).toLocaleDateString() %></span>
                                </div>
                            </div>
                        </div>
                        <div class="conversation-actions">
                            <a href="/chatroom/<%= conv._id %>" class="btn btn-primary btn-sm">
                                <i class="fas fa-eye"></i> View
                            </a>
                            <% if (conv.slaInfo.status !== 'closed') { %>
                            <button class="btn btn-success btn-sm" onclick="updateStatus('<%= conv._id %>', 'closed')">
                                <i class="fas fa-check"></i> Resolve
                            </button>
                            <% } %>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.sla-dashboard {
    display: grid;
    gap: 2rem;
}

.sla-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
}

.stat-item {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    background: var(--primary-color);
    color: white;
}

.stat-icon.positive {
    background: var(--success-color);
}

.stat-icon.warning {
    background: var(--warning-color);
}

.stat-icon.negative {
    background: var(--error-color);
}

.stat-details h3 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    color: var(--text-primary);
}

.stat-details p {
    margin: 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
}

.stat-details small {
    color: var(--text-muted);
    font-size: 0.75rem;
}

.sla-metrics {
    margin-top: 1rem;
}

.metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1.5rem;
}

.metric-item {
    text-align: center;
    padding: 1.5rem;
    background: var(--background-color);
    border-radius: 12px;
    border: 1px solid var(--border-color);
}

.metric-value {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
}

.metric-value.positive {
    color: var(--success-color);
}

.metric-value.warning {
    color: var(--warning-color);
}

.metric-value.negative {
    color: var(--error-color);
}

.metric-label {
    font-size: 0.9rem;
    color: var(--text-secondary);
    font-weight: 500;
    margin-bottom: 0.25rem;
}

.metric-target {
    font-size: 0.75rem;
    color: var(--text-muted);
}

/* Priority Queue Styles */
.priority-queue, .due-soon-queue, .conversations-by-status {
    margin-top: 2rem;
}

.card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem;
    border-bottom: 1px solid var(--border-color);
    background: var(--background-color);
    border-radius: 12px 12px 0 0;
}

.card-header h3 {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.badge {
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
}

.badge-danger {
    background: var(--error-color);
    color: white;
}

.badge-warning {
    background: var(--warning-color);
    color: white;
}

/* Conversation List Styles */
.conversation-list {
    display: grid;
    gap: 1rem;
}

.conversation-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--surface-color);
    transition: all 0.2s;
}

.conversation-item:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
}

.conversation-item.overdue {
    border-left: 4px solid var(--error-color);
    background: rgba(239, 68, 68, 0.05);
}

.conversation-item.due-soon {
    border-left: 4px solid var(--warning-color);
    background: rgba(245, 158, 11, 0.05);
}

.conversation-info {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex: 1;
}

.customer-avatar {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 0.9rem;
}

.conversation-details h4 {
    margin: 0 0 0.25rem 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
}

.conversation-details p {
    margin: 0 0 0.5rem 0;
    font-size: 0.85rem;
    color: var(--text-secondary);
}

.conversation-meta {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.intent-badge, .sla-badge, .time-badge {
    padding: 0.2rem 0.5rem;
    border-radius: 12px;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: capitalize;
}

.intent-query { background: #e0f2fe; color: #0277bd; }
.intent-complaint { background: #ffebee; color: #d32f2f; }
.intent-need_action { background: #fff3e0; color: #f57c00; }
.intent-feedback { background: #e8f5e8; color: #388e3c; }

.sla-new { background: #e3f2fd; color: #1976d2; }
.sla-pending { background: #fff3e0; color: #f57c00; }
.sla-overdue { background: #ffebee; color: #d32f2f; }
.sla-closed { background: #e8f5e8; color: #388e3c; }

.time-badge {
    background: var(--background-color);
    color: var(--text-muted);
}

.conversation-actions {
    display: flex;
    gap: 0.5rem;
}

.btn {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
}

.btn-sm {
    padding: 0.375rem 0.75rem;
    font-size: 0.75rem;
}

.btn-primary {
    background: var(--primary-color);
    color: white;
}

.btn-primary:hover {
    background: var(--primary-dark);
    color: white;
}

.btn-success {
    background: var(--success-color);
    color: white;
}

.btn-success:hover {
    background: #059669;
    color: white;
}

/* Status Filters */
.status-filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
}

.filter-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--border-color);
    background: var(--surface-color);
    color: var(--text-secondary);
    border-radius: 20px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
}

.filter-btn:hover {
    background: var(--primary-light);
    color: white;
    border-color: var(--primary-light);
}

.filter-btn.active {
    background: var(--primary-color);
    color: white;
    border-color: var(--primary-color);
}

@media (max-width: 768px) {
    .sla-stats {
        grid-template-columns: 1fr;
    }
    
    .metrics-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .conversation-item {
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
    }
    
    .conversation-actions {
        width: 100%;
        justify-content: flex-end;
    }
    
    .status-filters {
        justify-content: center;
    }
}
</style>

<script>
// Status filtering
document.addEventListener('DOMContentLoaded', function() {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const conversations = document.querySelectorAll('#allConversations .conversation-item');
    
    filterBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            // Update active button
            filterBtns.forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            
            const status = this.dataset.status;
            
            // Filter conversations
            conversations.forEach(conv => {
                if (status === 'all' || conv.dataset.status === status) {
                    conv.style.display = 'flex';
                } else {
                    conv.style.display = 'none';
                }
            });
        });
    });
});

// Update conversation status
function updateStatus(chatroomId, newStatus) {
    if (!confirm('Are you sure you want to update this conversation status?')) {
        return;
    }
    
    fetch(`/api/chatroom/${chatroomId}/status`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ status: newStatus })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Reload page to show updated data
            window.location.reload();
        } else {
            alert('Failed to update status: ' + (data.error || 'Unknown error'));
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('Failed to update status');
    });
}
</script>

<%- include('partials/layout-footer') %>