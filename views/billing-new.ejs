<%- include('partials/layout-header', { title: 'Billing & Usage', currentPage: 'billing' }) %>

<div class="content-header">
    <h1><i class="fas fa-credit-card"></i> Billing & Usage</h1>
    <p>Track API usage and conversation costs</p>
</div>

<div class="billing-grid">
    <div class="cost-card">
        <div class="cost-amount">₹0.00</div>
        <div class="cost-label">This Month</div>
    </div>
    <div class="cost-card">
        <div class="cost-amount">₹0.00</div>
        <div class="cost-label">Text Messages</div>
    </div>
    <div class="cost-card">
        <div class="cost-amount">₹0.00</div>
        <div class="cost-label">Audio Processing</div>
    </div>
    <div class="cost-card">
        <div class="cost-amount">₹0.00</div>
        <div class="cost-label">Image Analysis</div>
    </div>
</div>

<div class="card">
    <div class="card-content">
        <div class="coming-soon">
            <i class="fas fa-credit-card"></i>
            <h3>Billing & Cost Tracking</h3>
            <p>Detailed usage analytics, cost breakdowns, and billing reports coming in Phase 3</p>
            <div class="mt-4">
                <div class="btn btn-primary">
                    <i class="fas fa-download"></i> Export Usage Report
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.billing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.cost-card {
    background: var(--surface-color);
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--border-color);
    text-center;
}

.cost-amount {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--primary-color);
    margin-bottom: 0.5rem;
}

.cost-label {
    color: var(--text-secondary);
    font-size: 0.875rem;
}

.coming-soon {
    text-align: center;
    padding: 3rem 2rem;
}

.coming-soon i {
    font-size: 3rem;
    margin-bottom: 1rem;
    color: var(--primary-light);
}

.coming-soon h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
}

.coming-soon p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
}

.mt-4 {
    margin-top: 1.5rem;
}

@media (max-width: 768px) {
    .billing-grid {
        grid-template-columns: 1fr;
    }
}
</style>

<%- include('partials/layout-footer') %>