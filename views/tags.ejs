<%- include('partials/layout-header', { title: 'Tags Management', currentPage: 'tags' }) %>\n\n<div class=\"main-content\">\n    <div class=\"content-header\">\n        <h1><i class=\"fas fa-tags\"></i> Tags Management</h1>\n        <p>Manage conversation tags and auto-tagging rules</p>\n    </div>\n\n    <div class=\"tags-dashboard\">\n        <!-- Available Tags Section -->\n        <div class=\"card\">\n            <div class=\"card-header\">\n                <h3>Available Tags</h3>\n                <span class=\"badge\"><%= availableTags.length %> tags</span>\n            </div>\n            <div class=\"card-content\">\n                <div class=\"tags-grid\">\n                    <% availableTags.forEach(tag => { %>\n                        <span class=\"tag-item <%= tag %>\">\n                            <i class=\"fas fa-tag\"></i>\n                            <%= tag.replace('_', ' ') %>\n                        </span>\n                    <% }) %>\n                </div>\n            </div>\n        </div>\n\n        <!-- Conversations with Tags -->\n        <div class=\"card\">\n            <div class=\"card-header\">\n                <h3>Tagged Conversations</h3>\n                <div class=\"filter-controls\">\n                    <select id=\"tagFilter\" class=\"form-select\">\n                        <option value=\"\">All Tags</option>\n                        <% availableTags.forEach(tag => { %>\n                            <option value=\"<%= tag %>\"><%= tag.replace('_', ' ') %></option>\n                        <% }) %>\n                    </select>\n                </div>\n            </div>\n            <div class=\"card-content\">\n                <div class=\"conversations-list\">\n                    <% chatrooms.forEach(chatroom => { %>\n                        <div class=\"conversation-item\" data-tags=\"<%= (chatroom.tags || []).join(',') %>\">\n                            <div class=\"conversation-info\">\n                                <div class=\"phone-number\">\n                                    <i class=\"fab fa-whatsapp\"></i>\n                                    <%= chatroom.thread_id %>\n                                </div>\n                                <div class=\"last-message\">\n                                    <%= chatroom.last_message ? chatroom.last_message.substring(0, 50) + '...' : 'No messages' %>\n                                </div>\n                                <div class=\"timestamp\">\n                                    <%= chatroom.last_message_time ? new Date(chatroom.last_message_time).toLocaleDateString() : 'N/A' %>\n                                </div>\n                            </div>\n                            \n                            <div class=\"tags-section\">\n                                <div class=\"current-tags\">\n                                    <% if (chatroom.tags && chatroom.tags.length > 0) { %>\n                                        <% chatroom.tags.forEach(tag => { %>\n                                            <span class=\"tag <%= tag %>\">\n                                                <%= tag.replace('_', ' ') %>\n                                                <button class=\"remove-tag\" data-chatroom=\"<%= chatroom._id %>\" data-tag=\"<%= tag %>\">\n                                                    <i class=\"fas fa-times\"></i>\n                                                </button>\n                                            </span>\n                                        <% }) %>\n                                    <% } else { %>\n                                        <span class=\"no-tags\">No tags</span>\n                                    <% } %>\n                                </div>\n                                \n                                <div class=\"tag-actions\">\n                                    <select class=\"add-tag-select\" data-chatroom=\"<%= chatroom._id %>\">\n                                        <option value=\"\">Add tag...</option>\n                                        <% availableTags.forEach(tag => { %>\n                                            <% if (!chatroom.tags || !chatroom.tags.includes(tag)) { %>\n                                                <option value=\"<%= tag %>\"><%= tag.replace('_', ' ') %></option>\n                                            <% } %>\n                                        <% }) %>\n                                    </select>\n                                    <a href=\"/chatroom/<%= chatroom._id %>\" class=\"btn-view\">\n                                        <i class=\"fas fa-eye\"></i>\n                                    </a>\n                                </div>\n                            </div>\n                        </div>\n                    <% }) %>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n<style>\n.tags-dashboard {\n    display: grid;\n    gap: 2rem;\n}\n\n.tags-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));\n    gap: 1rem;\n}\n\n.tag-item {\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n    padding: 0.75rem 1rem;\n    background: var(--surface-color);\n    border: 1px solid var(--border-color);\n    border-radius: 8px;\n    font-weight: 500;\n    text-transform: capitalize;\n}\n\n.conversations-list {\n    display: grid;\n    gap: 1rem;\n}\n\n.conversation-item {\n    display: grid;\n    grid-template-columns: 1fr auto;\n    gap: 1rem;\n    padding: 1rem;\n    background: var(--surface-color);\n    border: 1px solid var(--border-color);\n    border-radius: 8px;\n    align-items: center;\n}\n\n.conversation-info {\n    display: grid;\n    gap: 0.25rem;\n}\n\n.phone-number {\n    font-weight: 600;\n    color: var(--primary-color);\n    display: flex;\n    align-items: center;\n    gap: 0.5rem;\n}\n\n.last-message {\n    color: var(--text-secondary);\n    font-size: 0.9rem;\n}\n\n.timestamp {\n    color: var(--text-muted);\n    font-size: 0.8rem;\n}\n\n.tags-section {\n    display: grid;\n    gap: 0.5rem;\n    min-width: 300px;\n}\n\n.current-tags {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 0.5rem;\n}\n\n.tag {\n    display: inline-flex;\n    align-items: center;\n    gap: 0.25rem;\n    padding: 0.25rem 0.5rem;\n    border-radius: 4px;\n    font-size: 0.8rem;\n    font-weight: 500;\n    text-transform: capitalize;\n}\n\n.tag.billing { background: #e3f2fd; color: #1976d2; }\n.tag.technical_support { background: #f3e5f5; color: #7b1fa2; }\n.tag.product_inquiry { background: #e8f5e8; color: #388e3c; }\n.tag.complaint { background: #ffebee; color: #d32f2f; }\n.tag.order_status { background: #fff3e0; color: #f57c00; }\n.tag.refund { background: #fce4ec; color: #c2185b; }\n.tag.general_query { background: #f5f5f5; color: #616161; }\n.tag.urgent { background: #ffcdd2; color: #d32f2f; }\n.tag.feedback { background: #e1f5fe; color: #0277bd; }\n\n.remove-tag {\n    background: none;\n    border: none;\n    color: inherit;\n    cursor: pointer;\n    padding: 0;\n    margin-left: 0.25rem;\n    opacity: 0.7;\n}\n\n.remove-tag:hover {\n    opacity: 1;\n}\n\n.no-tags {\n    color: var(--text-muted);\n    font-style: italic;\n    font-size: 0.9rem;\n}\n\n.tag-actions {\n    display: flex;\n    gap: 0.5rem;\n    align-items: center;\n}\n\n.add-tag-select {\n    padding: 0.25rem 0.5rem;\n    border: 1px solid var(--border-color);\n    border-radius: 4px;\n    background: white;\n    font-size: 0.9rem;\n}\n\n.btn-view {\n    padding: 0.25rem 0.5rem;\n    background: var(--primary-color);\n    color: white;\n    text-decoration: none;\n    border-radius: 4px;\n    font-size: 0.9rem;\n}\n\n.filter-controls {\n    display: flex;\n    gap: 1rem;\n}\n\n.form-select {\n    padding: 0.5rem;\n    border: 1px solid var(--border-color);\n    border-radius: 4px;\n    background: white;\n}\n</style>\n\n<script>\n// Tag filtering\ndocument.getElementById('tagFilter').addEventListener('change', function() {\n    const selectedTag = this.value;\n    const conversations = document.querySelectorAll('.conversation-item');\n    \n    conversations.forEach(conv => {\n        const tags = conv.dataset.tags.split(',');\n        if (!selectedTag || tags.includes(selectedTag)) {\n            conv.style.display = 'grid';\n        } else {\n            conv.style.display = 'none';\n        }\n    });\n});\n\n// Add tag functionality\ndocument.querySelectorAll('.add-tag-select').forEach(select => {\n    select.addEventListener('change', async function() {\n        const chatroomId = this.dataset.chatroom;\n        const newTag = this.value;\n        \n        if (!newTag) return;\n        \n        try {\n            const response = await fetch(`/api/chatroom/${chatroomId}/tags`, {\n                method: 'POST',\n                headers: {\n                    'Content-Type': 'application/json'\n                },\n                body: JSON.stringify({ \n                    tags: [...getCurrentTags(chatroomId), newTag] \n                })\n            });\n            \n            if (response.ok) {\n                location.reload();\n            }\n        } catch (error) {\n            console.error('Error adding tag:', error);\n        }\n    });\n});\n\n// Remove tag functionality\ndocument.querySelectorAll('.remove-tag').forEach(button => {\n    button.addEventListener('click', async function() {\n        const chatroomId = this.dataset.chatroom;\n        const tagToRemove = this.dataset.tag;\n        \n        try {\n            const currentTags = getCurrentTags(chatroomId);\n            const updatedTags = currentTags.filter(tag => tag !== tagToRemove);\n            \n            const response = await fetch(`/api/chatroom/${chatroomId}/tags`, {\n                method: 'POST',\n                headers: {\n                    'Content-Type': 'application/json'\n                },\n                body: JSON.stringify({ tags: updatedTags })\n            });\n            \n            if (response.ok) {\n                location.reload();\n            }\n        } catch (error) {\n            console.error('Error removing tag:', error);\n        }\n    });\n});\n\nfunction getCurrentTags(chatroomId) {\n    const conversation = document.querySelector(`[data-chatroom=\"${chatroomId}\"]`).closest('.conversation-item');\n    const tagsData = conversation.dataset.tags;\n    return tagsData ? tagsData.split(',').filter(tag => tag) : [];\n}\n</script>\n\n<%- include('partials/layout-footer') %>